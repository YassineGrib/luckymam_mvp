rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Children subcollection - users can manage their own children
      match /children/{childId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // Vaccinations subcollection - users can track vaccinations for their children
        match /vaccinations/{vaccinationId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Growth tracking subcollection (Phase 2)
        match /growth/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // Medical appointments subcollection (Phase 2)
        match /appointments/{apptId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
      
      // Capsules subcollection - users can manage their memory capsules
      match /capsules/{capsuleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Milestone Progress subcollection
      match /milestoneProgress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Default deny for other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}